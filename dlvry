        <label><input type="radio" name="delivery_type" value="home" id="home" onclick="toggleAddress()"> Home Delivery</label><br>
        <div id="address-field" style="display:none; margin-top:10px;">
            <label>Delivery Address:<br>
                <input type="text" name="delivery_address" style="width:300px;">
            </label>
