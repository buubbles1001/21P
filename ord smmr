<?php
session_start();
require_once 'db_connect.php';

if (!isset($_SESSION['user_id']) || !isset($_SESSION['pending_order']) || !isset($_SESSION['delivery_info'])) {
    header('Location: account.php');
    exit;
}
$user_id = $_SESSION['user_id'];
$cart = $_SESSION['pending_order'];
$delivery_info = $_SESSION['delivery_info'];

// Fetch products for display
$ids = implode(',', array_map('intval', array_keys($cart)));
$stmt = $pdo->query("SELECT product_id, name, price FROM products WHERE product_id IN ($ids)");
$products = $stmt->fetchAll();
$total = 0;
foreach ($products as $product) {
    $qty = $cart[$product['product_id']];
    $total += $qty * $product['price'];
}
$discount = $total * 0.10;
$final_total = $total - $discount;

// Handle Buy Now
if (isset($_POST['buy_now'])) {
    $order_status = 'Pending';
    $order_date = date('Y-m-d H:i:s');
    foreach ($products as $product) {
        $qty = $cart[$product['product_id']];
        $total_price = $qty * $product['price'];
        // Insert into orders
        $stmt = $pdo->prepare("INSERT INTO orders (user_id, product_id, quantity, total_price, order_status, order_date, discount_applied) VALUES (?, ?, ?, ?, ?, ?, ?)");
        $stmt->execute([$user_id, $product['product_id'], $qty, $total_price, $order_status, $order_date, $discount]);
        $order_id = $pdo->lastInsertId();
        // Insert into delivery
        $stmt2 = $pdo->prepare("INSERT INTO delivery (order_id, delivery_type, delivery_address, delivery_status, tracking_number) VALUES (?, ?, ?, ?, ?)");
        $stmt2->execute([$order_id, $delivery_info['delivery_type'], $delivery_info['delivery_address'], 'Pending', null]);
    }
    unset($_SESSION['cart']);
    unset($_SESSION['pending_order']);
    unset($_SESSION['delivery_info']);
    header('Location: account.php?order=placed');
    exit;
}
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Order Summary</title>
</head>
<body>
    <h1>Order Summary</h1>
    <ul>
        <?php foreach ($products as $product): 
            $qty = $cart[$product['product_id']];
            $subtotal = $qty * $product['price'];
        ?>
            <li>
                <strong><?= htmlspecialchars($product['name']) ?></strong> - $<?= number_format($product['price'], 2) ?> x <?= $qty ?> = $<?= number_format($subtotal, 2) ?>
            </li>
        <?php endforeach; ?>
    </ul>
    <h3>Subtotal: $<?= number_format($total, 2) ?></h3>
    <h3>Loyalty Discount (10%): -$<?= number_format($discount, 2) ?></h3>
    <h2>Total: $<?= number_format($final_total, 2) ?></h2>
    <form method="post">
        <button type="submit" name="buy_now">Buy Now</button>
    </form>
</body>
</html>
