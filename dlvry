<?php
session_start();
require_once 'db_connect.php';

if (!isset($_SESSION['user_id']) || !isset($_SESSION['pending_order'])) {
    header('Location: account.php');
    exit;
}
$user_id = $_SESSION['user_id'];
$cart = $_SESSION['pending_order'];

// Fetch products for display
$ids = implode(',', array_map('intval', array_keys($cart)));
$stmt = $pdo->query("SELECT product_id, name, price FROM products WHERE product_id IN ($ids)");
$products = $stmt->fetchAll();
$total = 0;
foreach ($products as $product) {
    $qty = $cart[$product['product_id']];
    $total += $qty * $product['price'];
}

// Handle delivery option selection
if (isset($_POST['delivery_type'])) {
    $delivery_type = $_POST['delivery_type'];
    $delivery_address = $delivery_type === 'home' ? trim($_POST['delivery_address']) : null;
    // Store delivery info in session and redirect to order summary
    $_SESSION['delivery_info'] = [
        'delivery_type' => $delivery_type,
        'delivery_address' => $delivery_address
    ];
    header('Location: order_summary.php');
    exit;
}
?>
