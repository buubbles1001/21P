<section class="hero">
    <div class="hero-text">
        <h1>Fresh Local Produce Delivered</h1>
        <p>Order fresh fruit, vegetables, and local products directly from trusted producers.</p>
        <a href="#" class="hero-btn">Shop Now</a>
    </div>
    
    <div class="hero-image">
        <img src="images/hero-image.jpg" alt="Fresh produce">
    </div>
</section>
.hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 60px 10%;
    background-color: #f5f5f5;
}

.hero-text {
    width: 50%;
}

.hero-text h1 {
    font-size: 48px;
    margin-bottom: 20px;
}

.hero-text p {
    font-size: 18px;
    margin-bottom: 20px;
}

.hero-btn {
    padding: 12px 25px;
    background-color: #2e7d32;
    color: white;
    text-decoration: none;
    border-radius: 5px;
}

.hero-image {
    width: 50%;
    text-align: right;
}

.hero-image img {
    max-width: 100%;
    height: auto;
    border-radius: 10px;
}

<section class="about">
    <h2 class="about-title">About Our Company</h2>

    <div class="about-grid">
        <div class="about-box">
            <h3>Our Mission</h3>
            <p>We aim to connect customers with local producers and provide fresh, high-quality products.</p>
        </div>

        <div class="about-box">
            <h3>Local Producers</h3>
            <p>We work with trusted local farms and producers to supply fresh food and goods.</p>
        </div>

        <div class="about-box">
            <h3>Sustainability</h3>
            <p>We support environmentally friendly farming and reduce food miles.</p>
        </div>

        <div class="about-box">
            <h3>Customer Focus</h3>
            <p>We make ordering simple and provide reliable delivery options.</p>
        </div>
    </div>
</section>

.about {
    padding: 60px 10%;
    background-color: #ffffff;
    text-align: center;
}

.about-title {
    font-size: 36px;
    margin-bottom: 40px;
}

.about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

.about-box {
    background-color: #f5f5f5;
    padding: 30px;
    border-radius: 10px;
}

.about-box h3 {
    margin-bottom: 15px;
}




