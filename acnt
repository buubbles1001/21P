<?php
session_start();
require_once 'db_connect.php';

// Check if user is signed in
if (!isset($_SESSION['user_id'])) {
    header('Location: login.php');
    exit;
}
$user_id = $_SESSION['user_id'];

// Fetch cart
$cart = isset($_SESSION['cart']) ? $_SESSION['cart'] : [];
$products = [];
$total = 0;
if ($cart) {
    $ids = implode(',', array_map('intval', array_keys($cart)));
    $stmt = $pdo->query("SELECT product_id, name, price FROM products WHERE product_id IN ($ids)");
    $products = $stmt->fetchAll();
}

// Handle buy cart
if (isset($_POST['buy_cart'])) {
    $_SESSION['pending_order'] = $cart;
    header('Location: delivery_option.php');
    exit;
}
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Account</title>
</head>
<body>
    <h1>Welcome to Your Account</h1>
    <h2>Your Cart</h2>
    <?php if ($products): ?>
        <ul>
            <?php foreach ($products as $product): 
                $qty = $cart[$product['product_id']];
                $subtotal = $qty * $product['price'];
                $total += $subtotal;
            ?>
                <li>
                    <strong><?= htmlspecialchars($product['name']) ?></strong> - $<?= number_format($product['price'], 2) ?> x <?= $qty ?> = $<?= number_format($subtotal, 2) ?>
                </li>
            <?php endforeach; ?>
        </ul>
        <h3>Total: $<?= number_format($total, 2) ?></h3>
        <form method="post">
            <button type="submit" name="buy_cart">Buy Cart</button>
        </form>
    <?php else: ?>
        <p>Your cart is empty.</p>
    <?php endif; ?>

<h2>Your Orders</h2>
<?php
#Retrieves all orders for a specific user, joins product names, and lists newest orders first
$stmt = $pdo->prepare('SELECT o.order_id, o.order_date, o.order_status, o.discount_applied, p.name, o.quantity, o.total_price FROM orders o JOIN products p ON o.product_id = p.product_id WHERE o.user_id = ? ORDER BY o.order_date DESC, o.order_id DESC');
$stmt->execute([$user_id]);
$orders = $stmt->fetchAll();
if ($orders):
    $current_order = null;
    foreach ($orders as $order):
        if ($current_order !== $order['order_id']):
            if ($current_order !== null) echo '</ul>';
            $current_order = $order['order_id'];
            echo '<div style="margin-top:20px; padding:10px; border:1px solid #ccc; border-radius:6px; background:#f9f9f9;">';
            echo '<strong>Order #' . $order['order_id'] . '</strong> | Date: ' . htmlspecialchars($order['order_date']) . ' | Status: ' . htmlspecialchars($order['order_status']) . '<ul>';
        endif;
        echo '<li>' . htmlspecialchars($order['name']) . ' - $' . number_format($order['total_price'] / $order['quantity'], 2) . ' x ' . $order['quantity'] . ' = $' . number_format($order['total_price'], 2) . '</li>';
        // Show discount only once per order
        if ($order['discount_applied'] && $order['discount_applied'] > 0) {
            echo '<li><em>Loyalty Discount: -$' . number_format($order['discount_applied'], 2) . '</em></li>';
        }
        // End of order block
        if (next($orders) === false || $current_order !== $orders[key($orders)]['order_id']) {
            echo '</ul></div>';
        }
    endforeach;
else:
    echo '<p>You have no orders yet.</p>';
endif;
?>
</body>
</html>
