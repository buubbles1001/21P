    die("Invalid product");
}

/* Handle description */
if ($desc_type === "append") {
    $description = $product['description'] . " " . $description;
}

/* Update query */
$stmt = $pdo->prepare("
    UPDATE products 
    SET price = COALESCE(?, price),
        stock_quantity = COALESCE(?, stock_quantity),
        description = COALESCE(?, description)
    WHERE product_id = ?
");

$stmt->execute([
    $price !== '' ? $price : null,
    $stock !== '' ? $stock : null,
    $description !== '' ? $description : null,
    $product_id
]);

